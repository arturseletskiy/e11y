#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

echo "🔧 Setting up E11y development environment..."
echo ""

# Configure bundle to exclude integration dependencies by default
echo "📦 Configuring bundle (excluding integration group)..."
bundle config set --local without 'integration'

# Install dependencies
echo "📦 Installing dependencies..."
bundle install

echo ""
echo "✅ Setup complete!"
echo ""
echo "Available commands:"
echo "  bin/console            - Interactive console"
echo "  bundle exec rspec      - Run unit tests (fast)"
echo "  bin/test-integration   - Run integration tests (requires Docker)"
echo ""
echo "For integration tests, run: bundle install --with integration"
echo "See docs/testing/integration-tests.md for more info."
